# Database
DATABASE_URL=postgresql+asyncpg://ptcg:ptcg@localhost:5432/ptcgdb
POSTGRES_USER=ptcg
POSTGRES_PASSWORD=ptcg
POSTGRES_DB=ptcgdb

# Redis
REDIS_URL=redis://localhost:6379/0

# pokemontcg.io (optional — raises rate limit from 1000/day to unlimited)
POKEMONTCG_API_KEY=

# Google Cloud Vision (set path to service account JSON, or leave empty for phash-only mode)
GOOGLE_APPLICATION_CREDENTIALS=
VISION_API_ENABLED=false

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
