# Database (SQLite for local dev — no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./ptcg.db

# Redis (leave empty to disable caching in local dev)
REDIS_URL=

# pokemontcg.io (optional — raises rate limit from 1000/day to unlimited)
POKEMONTCG_API_KEY=

# Scrydex API (graded prices + Japanese card prices)
SCRYDEX_API_KEY=
SCRYDEX_TEAM_ID=

# Anthropic API (Claude vision for card recognition)
ANTHROPIC_API_KEY=

# Google Gemini API (card vision recognition)
GEMINI_API_KEY=AIzaSyBlP_0E-ujwce07znKh57asb_cM3DaQXkE

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
